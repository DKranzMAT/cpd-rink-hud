{% extends '_layout' %}
{% block title %}{{ entry.title }} — CPD Rink HUD{% endblock %}

{% block content %}

<div class="rink-detail">

  <div class="rink-header">
    {% if entry.currentStatus %}
      {% set status = entry.currentStatus %}
      {% set colorMap = {
        'Open': 'green',
        'Closed': 'red',
        'Weather Hold': 'yellow',
        'Maintenance': 'orange',
        'Seasonal Closure': 'gray'
      } %}
      <span class="status-badge status--{{ colorMap[status] ?? 'gray' }}">{{ status }}</span>
    {% endif %}

    <h1>{{ entry.title }}</h1>
    <p>{{ entry.parkName }} · {{ entry.neighborhood }}</p>
    <p>{{ entry.address }}</p>
  </div>

  <div class="rink-meta">
    <span>{{ entry.isIndoor ? 'Indoor' : 'Outdoor' }}</span>
    {% if entry.yearRound %}
      <span>Year-Round</span>
    {% else %}
      {% if entry.seasonOpenDate and entry.seasonCloseDate %}
        <span>Season: {{ entry.seasonOpenDate|date('M j') }} – {{ entry.seasonCloseDate|date('M j') }}</span>
      {% endif %}
    {% endif %}
  </div>

  <div class="hours-block">
    <h3>Hours</h3>
    {% if entry.publicSkateOpen and entry.publicSkateClose %}
      <p>Public Skate: {{ entry.publicSkateOpen|date('g:i A') }} – {{ entry.publicSkateClose|date('g:i A') }}</p>
    {% endif %}
    {% if entry.hockeyHoursOpen and entry.hockeyHoursClose %}
      <p>Hockey: {{ entry.hockeyHoursOpen|date('g:i A') }} – {{ entry.hockeyHoursClose|date('g:i A') }}</p>
    {% endif %}
    {% if entry.hockeyDaysAvailable | length %}
      <p>Hockey Days:
        {% for day in entry.hockeyDaysAvailable %}
          <span class="badge">{{ day.label }}</span>
        {% endfor %}
      </p>
    {% endif %}
  </div>

  {% if entry.programsOffered | length %}
  <div class="programs">
    <h3>Programs</h3>
    {% for program in entry.programsOffered %}
      <span class="badge">{{ program.label }}</span>
    {% endfor %}
  </div>
  {% endif %}

  {% if entry.amenities | length %}
  <div class="amenities">
    <h3>Amenities</h3>
    {% for amenity in entry.amenities %}
      <span class="badge">{{ amenity.label }}</span>
    {% endfor %}
  </div>
  {% endif %}

  {% if entry.statusNote %}
  <div class="status-note">⚠️ {{ entry.statusNote }}</div>
  {% endif %}

  {% if entry.cpdDetailPageUrl %}
  <a class="cpd-link" href="{{ entry.cpdDetailPageUrl }}" target="_blank">View on CPD →</a>
  {% endif %}

  <a class="back-link" href="/">← Back to all rinks</a>

</div>

{% endblock %}