<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}CPD Rink HUD{% endblock %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600&family=JetBrains+Mono:wght@400;600&family=Inter:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/hud.css">
</head>
<body class="hud-dark">

  <header class="hud-header">
    <h1>CPD Rink HUD</h1>
    <div class="header-right">
      <span class="season-label">2026-27 Season</span>
      <button class="theme-toggle" onclick="toggleTheme()">
        <span id="theme-label">☀ Light</span>
      </button>
    </div>
  </header>

  {% block content %}{% endblock %}

  <script>
    const saved = localStorage.getItem('rinkTheme') || 'dark';
    document.body.classList.add(saved === 'light' ? 'hud-light' : 'hud-dark');

    function toggleTheme() {
      const isLight = document.body.classList.contains('hud-light');
      document.body.classList.toggle('hud-light', !isLight);
      document.body.classList.toggle('hud-dark', isLight);
      localStorage.setItem('rinkTheme', isLight ? 'dark' : 'light');
      document.getElementById('theme-label').textContent = isLight ? '☀ Light' : '● Dark';
    }

    document.addEventListener('DOMContentLoaded', () => {
      const isLight = document.body.classList.contains('hud-light');
      document.getElementById('theme-label').textContent = isLight ? '● Dark' : '☀ Light';
    });
  </script>

</body>
</html>