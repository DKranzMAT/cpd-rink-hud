{% extends '_layout' %}
{% block title %}CPD Rink HUD — Chicago Park District Ice Rinks{% endblock %}

{% block content %}

<div class="filters">
  <button class="active" data-filter="all">All Rinks</button>
  <button data-filter="indoor">Indoor</button>
  <button data-filter="outdoor">Outdoor</button>
</div>

{% set rinks = craft.entries()
  .section('iceRinks')
  .orderBy('neighborhood asc')
  .all() %}

{% if rinks | length %}
<div class="rink-grid">
  {% for rink in rinks %}
  <div class="rink-card" data-type="{{ rink.isIndoor.value ? 'indoor' : 'outdoor' }}">

    {% if rink.currentStatus.value %}
      {% set status = rink.currentStatus.value %}
      {% set colorMap = {
        'Open': 'green',
        'Closed': 'red',
        'Weather Hold': 'yellow',
        'Maintenance': 'orange',
        'Seasonal Closure': 'gray'
      } %}
      <span class="status-badge status--{{ colorMap[status] ?? 'gray' }}">{{ status }}</span>
    {% endif %}

    <h2>{{ rink.title }}</h2>
    <p class="park-name">{{ rink.parkName }}</p>
    <p class="neighborhood">{{ rink.neighborhood.label }}</p>

    {% if rink.publicSkateOpen and rink.publicSkateClose %}
    <div class="hours">
      ⏱ {{ rink.publicSkateOpen|date('g:i A') }} – {{ rink.publicSkateClose|date('g:i A') }}
    </div>
    {% endif %}

    {% if rink.isIndoor.value %}
      <span class="program-badge">🏠 Indoor</span>
    {% endif %}

    <a href="{{ rink.url }}">Details →</a>

  </div>
  {% endfor %}
</div>

{% else %}
<div class="no-rinks">
  <p>No rinks found. Add entries in the control panel.</p>
</div>
{% endif %}

<script>
  document.querySelectorAll('.filters button').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filters button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      document.querySelectorAll('.rink-card').forEach(card => {
        card.style.display = (filter === 'all' || card.dataset.type === filter) ? '' : 'none';
      });
    });
  });
</script>

{% endblock %}